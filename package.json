{
  "name": "virtualcode",
  "version": "2.2.1",
  "description": "OpenCode plugin that bridges your terminal sessions with Telegram",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    }
  },
  "files": [
    "dist",
    "install.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "postinstall": "node ./install.js",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShaikhWarsi/VirtualCode.git"
  },
  "bugs": {
    "url": "https://github.com/ShaikhWarsi/VirtualCode/issues"
  },
  "homepage": "https://github.com/ShaikhWarsi/VirtualCode#readme",
  "keywords": [
    "opencode",
    "telegram",
    "plugin",
    "ai",
    "llm",
    "bridge",
    "remote",
    "mobile"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.8",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
